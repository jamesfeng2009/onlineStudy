// Prisma schema for the online learning platform
generator client {
  provider = "prisma-client-js"
  output   = "../server/lib/prisma-generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Language {
  code    String @id
  name    String
  native  String
  flag    String
  tagline String
  levels  Json
  status  String @default("active") // 'active' | 'coming_soon'

  courses   Course[]
  wordBank  WordBank[]
  quizzes   Quiz[]
  listening Listening[]
  speaking  Speaking[]
  users     User[]

  @@map("languages")
}

model Course {
  id           String  @id @default(uuid())
  languageCode String
  title        String
  level        String
  levelGroup   String // beginner | intermediate | advanced
  description  String
  lessons      Int
  minutes      Int
  cover        String
  tags         Json
  vipOnly      Boolean @default(false)
  courseOrder  Int     @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@map("courses")
}

model WordBank {
  id              String  @id @default(uuid())
  languageCode    String
  level           String
  word            String
  phonetic        String?
  exampleSentence String
  vocabOrder      Int     @default(0)

  language     Language              @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  translations WordBankTranslation[]

  @@index([languageCode, level])
  @@map("word_bank")
}

model WordBankTranslation {
  id                 String  @id @default(uuid())
  wordBankId         String
  baseLanguageCode   String // 用户母语/释义语言，如 en/zh/ja/ko
  translation        String
  exampleTranslation String?

  wordBank WordBank @relation(fields: [wordBankId], references: [id], onDelete: Cascade)

  @@unique([wordBankId, baseLanguageCode])
  @@index([baseLanguageCode])
  @@map("word_bank_translations")
}

model Quiz {
  id           String   @id @default(uuid())
  languageCode String
  level        String
  options      Json // string[]
  answer       Int // index of correct option
  quizOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  language     Language          @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  translations QuizTranslation[]

  @@index([languageCode, level])
  @@map("quizzes")
}

model QuizTranslation {
  id               String @id @default(uuid())
  quizId           String
  baseLanguageCode String
  question         String
  explain          String

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, baseLanguageCode])
  @@index([baseLanguageCode])
  @@map("quiz_translations")
}

model Listening {
  id           String @id @default(uuid())
  languageCode String
  level        String
  title        String
  script       String
  blanks       Json // { index: number; answer: string }[]
  listenOrder  Int    @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@index([languageCode, level])
  @@map("listening")
}

model Speaking {
  id           String  @id @default(uuid())
  languageCode String
  level        String
  phrase       String
  translation  String
  phonetic     String?
  speakOrder   Int     @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@index([languageCode, level])
  @@map("speaking")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  username          String
  passwordHash      String
  avatar            String?
  level             Int      @default(1)
  exp               Int      @default(0)
  streak            Int      @default(0)
  lastActive        DateTime @default(now())
  uiLanguage        String   @default("en") // 界面语言：en/zh/ja/ko/...
  nativeLanguage    String   @default("en") // 学习释义语言：en/zh/ja/ko/...
  targetLanguage    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  role              String   @default("user") // user | vip | admin
  goalMinutesPerDay Int      @default(30)
  jwtVersion        Int      @default(0)

  language     Language          @relation(fields: [targetLanguage], references: [code], onDelete: Restrict)
  progressDays UserProgressDay[]
  posts        Post[]
  likedPosts   LikePost[]
  comments     Comment[]
  subscription Subscription?

  @@map("users")
}

model UserProgressDay {
  id               String   @id @default(uuid())
  userId           String
  studyDate        DateTime
  minutes          Int      @default(0)
  wordsLearned     Int      @default(0)
  wordCorrect      Int      @default(0)
  wordTotal        Int      @default(0)
  quizzesDone      Int      @default(0)
  quizCorrect      Int      @default(0)
  quizTotal        Int      @default(0)
  speakingMinutes  Int      @default(0)
  listeningMinutes Int      @default(0)
  moduleScores     Json     @default("{\"words\":0,\"grammar\":0,\"listening\":0,\"speaking\":0}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, studyDate])
  @@map("user_progress_days")
}

model Post {
  id        String   @id @default(uuid())
  authorId  String
  topic     String
  content   String
  createdAt DateTime @default(now())

  author   User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    LikePost[]
  comments Comment[]

  @@map("posts")
}

model LikePost {
  id     String @id @default(uuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("like_posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  status               String    @default("inactive")
  tier                 String    @default("free") // free | basic | vip
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  amountTotal          Int       @default(0)
  currency             String    @default("usd")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// Stripe webhook 事件记录（幂等性保证）
model StripeEvent {
  id          String   @id // Stripe event ID (evt_xxx)
  type        String // event type: checkout.session.completed, etc.
  processedAt DateTime @default(now())
  payload     Json // 原始 event payload（用于审计）
  userId      String? // 关联用户（可选，从 metadata 提取）

  @@map("stripe_events")
}
