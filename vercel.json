{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "cleanUrls": true,
  "functions": {
    "api/[...all].ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/((?!assets/|favicon\\.svg|api/).*)", "destination": "/" }
  ]
}
