{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "bash scripts/vercel-install.sh",
  "framework": null,
  "cleanUrls": false,
  "regions": ["hnd1"],
  "functions": {
    "api/handler.ts": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "redirects": [
    { "source": "/jp", "destination": "/ja", "permanent": true },
    { "source": "/jp/:path*", "destination": "/ja/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler?__path=:path*" },
    { "source": "/sitemap.xml", "destination": "/api/handler?__path=seo/sitemap" },
    { "source": "/robots.txt", "destination": "/api/handler?__path=seo/robots" },
    { "source": "/rss.xml", "destination": "/api/handler?__path=seo/rss" },
    { "source": "/((?!assets/|favicon\\.svg|api/).*)", "destination": "/" }
  ]
}
