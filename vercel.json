{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "bash scripts/vercel-install.sh",
  "framework": null,
  "cleanUrls": true,
  "toolbar": false,
  "regions": ["hnd1"],
  "functions": {
    "api/handler.ts": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler?__path=:path*" },
    { "source": "/((?!assets/|favicon\\.svg|api/).*)", "destination": "/" }
  ]
}
