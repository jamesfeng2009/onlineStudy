          "冠词",
          "可数/不可数名词"
        ]
      },
      "B1": {
        "name": "中级",
        "goals": [
          "处理旅行中的大多数情况",
          "认识约2,500–3,000个词汇",
          "阅读日常书面材料和简短新闻文章",
          "简单连贯地口头或书面描述经历和观点"
        ],
        "grammar": [
          "现在完成时",
          "被动语态",
          "条件句",
          "关系从句",
          "情态动词"
        ]
      },
      "B2": {
        "name": "中级进阶",
        "goals": [
          "理解复杂文本和抽象主题的主要思想",
          "认识约4,000–5,000个词汇",
          "与母语使用者进行流利且自然的交流",
          "撰写详细的观点和议论文"
        ],
        "grammar": [
          "虚拟语气",
          "过去完成时",
          "非限定动词",
          "倒装句",
          "名词性从句"
        ]
      },
      "C1": {
        "name": "高级",
        "goals": [
          "理解篇幅较长、要求较高的文本和隐含意义",
          "认识约8,000个词汇",
          "流利、自然地表达思想，用于社交、学术和专业场合",
          "撰写清晰、结构良好的复杂文本"
        ],
        "grammar": [
          "复杂从句嵌套",
          "高级虚拟语气",
          "修辞倒装",
          "独立主格结构"
        ]
      },
      "C2": {
        "name": "精通",
        "goals": [
          "几乎毫不费力地理解所听到或读到的一切",
          "认识约16,000个词汇",
          "以接近母语者的精确度表达细微差别",
          "处理学术、文学和专业领域的复杂文本"
        ],
        "grammar": [
          "全面掌握语法",
          "语域和文体意识",
          "修辞手法运用"
        ]
      }
    },
