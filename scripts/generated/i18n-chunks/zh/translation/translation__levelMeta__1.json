          "名词单复数"
        ]
      },
      "A2": {
        "name": "初级进阶",
        "goals": [
          "处理购物、问路、点餐等常见日常情境",
          "认识约1,500个词汇",
          "阅读简短通知、广告和电子邮件",
          "撰写100-150字的日常生活描述"
        ],
        "grammar": [
          "一般过去时",
          "现在进行时",
