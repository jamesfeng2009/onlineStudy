# Supabase Postgres (Tokyo region) - update with your connection string
DATABASE_URL=postgres://postgres:password@localhost:5432/linguaverse?schema=public

# Fastify
HOST=0.0.0.0
PORT=3001

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (optional)
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_VIP=price_xxx

# Frontend
FRONTEND_URL=http://localhost:5173

# Gemini (Google AI Studio) — quiz generator
# Get a key from https://aistudio.google.com/apikey
# Default model: gemini-2.0-flash (fast, cheap, multilingual).
# Other good options: gemini-2.5-flash, gemini-1.5-pro.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Hard cap on estimated spend per run. The script aborts if the
# running cost estimate crosses this threshold. Set to a high
# value if you want to opt out. Defaults to 1.00 if unset.
# Same-model-name caveat: gemini-2.5-flash and friends are the
# SAME alias for free-tier and paid-tier keys; the only thing
# that determines whether you pay is whether the key is bound
# to a billing account. Keep the cap low if you bind a card.
GEMINI_MAX_COST_USD=1.00
# Override the rate the script uses to estimate spend if you
# switch to a model whose pricing differs from the 2.5 Flash
# defaults below.
GEMINI_COST_PER_1M_IN=0.30
GEMINI_COST_PER_1M_OUT=2.50
