# Supabase Postgres (Tokyo region) - update with your connection string
DATABASE_URL=postgres://postgres:password@localhost:5432/linguaverse?schema=public

# Fastify
HOST=0.0.0.0
PORT=3001

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (optional)
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_VIP=price_xxx

# Frontend
FRONTEND_URL=http://localhost:5173

# Backend public URL (OAuth redirect_uri must be reachable by Google/GitHub)
# Local dev defaults to http://localhost:3001. In production set this to your
# public API origin (e.g. https://api.example.com or https://example.com if
# the API is served from the same origin as the frontend).
BACKEND_URL=http://localhost:3001

# OAuth (Google + GitHub) — leave blank to disable a provider
# Google: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BACKEND_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
# Authorization callback URL: ${BACKEND_URL}/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# LLM provider (used by scripts/generate-quizzes-gemini.ts)
# ============================================
# Gemini is restricted in mainland China ("User location is not
# supported"). For CN access, set LLM_PROVIDER=openrouter or
# LLM_PROVIDER=doubao. Default: gemini.
#   gemini      → Google AI Studio. Free at aistudio.google.com/apikey.
#                 Not reachable from CN. Same model name for free/paid.
#   openrouter  → Unified router. 1 key works for Gemini / Claude /
#                 GPT / Qwen / DeepSeek. CN-accessible.
#                 Free key at openrouter.ai/keys (no payment needed
#                 for free-tier models; some need $5 top-up).
#   doubao      → 字节火山引擎 Ark. China-direct, real-name KYC.
#                 Open https://www.volcengine.com/product/ark and
#                 create an API key from the console.
#
# Get a key from the URL matching LLM_PROVIDER, then paste into the
# matching _API_KEY variable below.
LLM_PROVIDER=gemini

# Provider-specific keys (only the one matching LLM_PROVIDER is used)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2.0-mini

# Cost cap & per-1M rates. Defaults match Gemini 2.5 Flash; override
# to match the model you actually use. The script aborts once the
# running total estimate crosses LLM_MAX_COST_USD.
LLM_MAX_COST_USD=1.00
LLM_COST_PER_1M_IN=0.30
LLM_COST_PER_1M_OUT=2.50
