# Supabase Postgres (Tokyo region) - update with your connection string
DATABASE_URL=postgres://postgres:password@localhost:5432/linguaverse?schema=public

# Fastify
HOST=0.0.0.0
PORT=3001

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (optional)
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_VIP=price_xxx

# Frontend
FRONTEND_URL=http://localhost:5173

# Backend public URL (OAuth redirect_uri must be reachable by Google/GitHub)
# Local dev defaults to http://localhost:3001. In production set this to your
# public API origin (e.g. https://api.example.com or https://example.com if
# the API is served from the same origin as the frontend).
BACKEND_URL=http://localhost:3001

# OAuth (Google + GitHub) — leave blank to disable a provider
# Google: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BACKEND_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
# Authorization callback URL: ${BACKEND_URL}/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# LLM provider (used by scripts/generate-quizzes-gemini.ts)
# ============================================
# Gemini is restricted in mainland China ("User location is not
# supported"). For CN access, set LLM_PROVIDER=openrouter or
# LLM_PROVIDER=doubao. Default: gemini.
#   gemini      → Google AI Studio. Free at aistudio.google.com/apikey.
#                 Not reachable from CN. Same model name for free/paid.
#   openrouter  → Unified router. 1 key works for Gemini / Claude /
#                 GPT / Qwen / DeepSeek. CN-accessible.
#                 Free key at openrouter.ai/keys (no payment needed
#                 for free-tier models; some need $5 top-up).
#   doubao      → 字节火山引擎 Ark. China-direct, real-name KYC.
#                 Open https://www.volcengine.com/product/ark and
#                 create an API key from the console.
#
# Get a key from the URL matching LLM_PROVIDER, then paste into the
# matching _API_KEY variable below.
LLM_PROVIDER=gemini

# Provider-specific keys (only the one matching LLM_PROVIDER is used)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
# DeepSeek V3 Chat is free on OpenRouter (50 calls/day, no card).
# Once that quota is exhausted, switch to `google/gemini-2.5-flash`
# (paid) or `qwen/qwen-2.5-72b-instruct:free` (also free).
OPENROUTER_MODEL=deepseek/deepseek-chat:free
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2.0-mini

# P4-4: DashScope (Qwen) for East Asian languages
# Content generation scripts route zh/ja/ko/yue to Qwen via DashScope
# (better quality for CJK languages), other languages use Gemini.
# Get a key at https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen2.5-72b-instruct

# Cost cap & per-1M rates. Defaults match Gemini 2.5 Flash; override
# to match the model you actually use. The script aborts once the
# running total estimate crosses LLM_MAX_COST_USD.
LLM_MAX_COST_USD=1.00
LLM_COST_PER_1M_IN=0.30
LLM_COST_PER_1M_OUT=2.50

# Runtime AI explanation quota (P3-1).
# Each logged-in user can call the /ai-explain/* endpoints this many
# times per UTC day. Cache hits (same targetType+targetId+promptHash)
# do NOT count against the quota. Set to a large number to effectively
# disable the limit.
AI_DAILY_LIMIT=50

# ============================================
# SEO / Webmaster tools
# ============================================

# Bing IndexNow — 批量提交接口的访问 token（POST /api/seo/indexnow 用）
# 生成方式: openssl rand -hex 16
# IndexNow key 已硬编码在 server/lib/indexnow.ts 中，对应 public/04507e3f9af5e9fcaf36e0302f7aeb4a.txt
# 此 token 仅用于鉴权批量提交接口，避免被随意触发
INDEXNOW_ADMIN_TOKEN=

# Google Search Console 站点验证（前端 HTML meta，必须 VITE_ 前缀才能被 Vite 注入）
# 获取: https://search.google.com/search-console → Add property → HTML tag → 复制 content 值
VITE_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools 站点验证（前端 HTML meta）
# 获取: https://www.bing.com/webmasters → Add site → HTML meta tag → 复制 content 值
VITE_BING_SITE_VERIFICATION=

# Cloudflare Web Analytics（前端 script 标签 token）
# 获取: Cloudflare dashboard → lang-oria.com → Analytics & Logs → Web Analytics → Enable → 复制 tag ID
VITE_CF_WEB_ANALYTICS_TOKEN=
