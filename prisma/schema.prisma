// Prisma schema for the online learning platform
generator client {
  provider = "prisma-client-js"
  output   = "../server/lib/prisma-generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // pooler (6543): 应用运行时用
  directUrl = env("DIRECT_URL")          // 直连 (5432): migrate/推送 schema 用
}

model Language {
  code    String   @id
  name    String
  native  String
  flag    String
  tagline String
  levels  Json
  status  String   @default("active") // 'active' | 'coming_soon'

  courses   Course[]
  wordBank  WordBank[]
  quizzes   Quiz[]
  listening Listening[]
  speaking  Speaking[]
  readingPassages ReadingPassage[]
  writingPrompts  WritingPrompt[]
  users     User[]

  @@map("languages")
}

model Course {
  id           String   @id @default(uuid())
  languageCode String
  title        String
  level        String
  levelGroup   String   // beginner | intermediate | advanced
  description  String
  lessons      Int
  minutes      Int
  cover        String
  tags         Json
  vipOnly      Boolean  @default(false)
  courseOrder  Int      @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  userProgress UserCourseProgress[]
  units        Unit[]

  @@map("courses")
}

model WordBank {
  id              String                  @id @default(uuid())
  languageCode    String
  level           String
  word            String
  phonetic        String?
  exampleSentence String
  vocabOrder      Int                     @default(0)

  language      Language                @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  translations  WordBankTranslation[]
  userReviews   UserWordReview[]

  @@map("word_bank")
  @@index([languageCode, level])
}

model WordBankTranslation {
  id                 String   @id @default(uuid())
  wordBankId         String
  baseLanguageCode   String   // 用户母语/释义语言，如 en/zh/ja/ko/es/fr/de
  translation        String
  exampleTranslation String?

  wordBank WordBank @relation(fields: [wordBankId], references: [id], onDelete: Cascade)

  @@map("word_bank_translations")
  @@unique([wordBankId, baseLanguageCode])
  @@index([baseLanguageCode])
  @@index([baseLanguageCode, wordBankId])
}

model Quiz {
  id           String             @id @default(uuid())
  languageCode String
  level        String
  options      Json               // string[]
  answer       Int                // index of correct option
  quizOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  language      Language           @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  translations  QuizTranslation[]
  userReviews   UserQuizReview[]

  @@map("quizzes")
  @@index([languageCode, level])
}

model QuizTranslation {
  id               String @id @default(uuid())
  quizId           String
  baseLanguageCode String
  question         String
  explain          String

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_translations")
  @@unique([quizId, baseLanguageCode])
  @@index([baseLanguageCode])
}

model Listening {
  id           String @id @default(uuid())
  languageCode String
  level        String
  title        String
  script       String
  blanks       Json   // { index: number; answer: string }[]
  listenOrder  Int    @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  userProgress UserListeningProgress[]
  userReviews  UserListeningReview[]

  @@map("listening")
  @@index([languageCode, level])
}

model Speaking {
  id           String  @id @default(uuid())
  languageCode String
  level        String
  phrase       String
  translation  String
  phonetic     String?
  speakOrder   Int     @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  userProgress UserSpeakingProgress[]
  userReviews  UserSpeakingReview[]

  @@map("speaking")
  @@index([languageCode, level])
}

model User {
  id               String              @id @default(uuid())
  email            String              @unique
  username         String
  passwordHash     String?
  avatar           String?
  level            Int                 @default(1)
  exp              Int                 @default(0)
  streak           Int                 @default(0)
  lastActive       DateTime            @default(now())
  uiLanguage       String              @default("en") // 界面语言：en/zh/ja/ko/...
  nativeLanguage   String              @default("en") // 学习释义语言：en/zh/ja/ko/...
  targetLanguage   String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  role             String              @default("user") // user | vip | admin
  goalMinutesPerDay Int                @default(30)
  jwtVersion       Int                 @default(0)
  // OAuth 绑定信息：同一邮箱可关联多个 provider，null 表示该账号由密码注册
  oauthProvider    String?
  oauthId          String?
  // 邮箱验证：OAuth 用户默认视为已验证；密码注册用户默认 false
  emailVerified    Boolean             @default(false)

  language        Language             @relation(fields: [targetLanguage], references: [code], onDelete: Restrict)
  progressDays    UserProgressDay[]
  posts           Post[]
  likedPosts      LikePost[]
  comments        Comment[]
  subscription    Subscription?
  // P0: 学习进度
  wordReviews     UserWordReview[]
  courseProgress  UserCourseProgress[]
  quizReviews     UserQuizReview[]
  // P1: 练习记录
  listeningProgress UserListeningProgress[]
  speakingProgress  UserSpeakingProgress[]
  achievements      UserAchievement[]
  // P0-1: 课时进度
  lessonProgress   UserLessonProgress[]
  // P0-3: 分级测试结果（每语言一条最新记录）
  placementResults PlacementResult[]
  // P1-2: 阅读理解进度
  readingProgress  UserReadingProgress[]
  // P1-3: SM-2 复习队列（听力 / 口语）
  listeningReviews UserListeningReview[]
  speakingReviews  UserSpeakingReview[]
  // P2-1: League 排行榜
  leagueStandings LeagueStanding[]
  // P2-2: CEFR 自评
  cefrSelfAssessments CefrSelfAssessment[]
  // P2-3: 写作提交记录
  writingSubmissions UserWritingSubmission[]

  @@unique([oauthProvider, oauthId])
  @@map("users")
}

model UserProgressDay {
  id              String   @id @default(uuid())
  userId          String
  studyDate       DateTime
  minutes         Int      @default(0)
  wordsLearned    Int      @default(0)
  wordCorrect     Int      @default(0)
  wordTotal       Int      @default(0)
  quizzesDone     Int      @default(0)
  quizCorrect     Int      @default(0)
  quizTotal       Int      @default(0)
  speakingMinutes Int      @default(0)
  listeningMinutes Int     @default(0)
  moduleScores    Json     @default("{\"words\":0,\"grammar\":0,\"listening\":0,\"speaking\":0}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, studyDate])
  @@map("user_progress_days")
}

model Post {
  id        String   @id @default(uuid())
  authorId  String
  topic     String
  content   String
  createdAt DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    LikePost[]
  comments Comment[]

  @@map("posts")
}

model LikePost {
  id     String @id @default(uuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("like_posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Subscription {
  id                  String   @id @default(uuid())
  userId              String   @unique
  stripeCustomerId    String?
  stripeSubscriptionId String?
  stripePriceId       String?
  status              String   @default("inactive")
  tier                String   @default("free") // free | basic | vip
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean  @default(false)
  amountTotal         Int      @default(0)
  currency            String   @default("usd")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// Stripe webhook 事件记录（幂等性保证）
model StripeEvent {
  id            String   @id // Stripe event ID (evt_xxx)
  type          String   // event type: checkout.session.completed, etc.
  processedAt   DateTime @default(now())
  payload       Json     // 原始 event payload（用于审计）
  userId        String?  // 关联用户（可选，从 metadata 提取）

  @@map("stripe_events")
}

// Blog posts (CMS) —— Markdown 内容，多语言由 baseLanguageCode 区分
model BlogPost {
  id               String   @id @default(uuid())
  slug             String
  title            String
  excerpt          String
  content          String   // 整篇 markdown 文本（不再用 JSON 数组）
  tag              String
  readTime         String   @default("5 min read")
  coverEmoji       String?  // 文章封面 emoji，备用
  coverImageUrl    String?  // OG 图/封面图 URL（可选）
  tldr             String?  // 1-2 句简短引子
  seoTitle         String?  // SEO 独立标题
  seoDescription   String?  // SEO 独立描述
  baseLanguageCode String   @default("en") // en/zh/ja/ko/es/fr/de
  status           String   @default("draft") // draft | published
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  revisions BlogPostRevision[]
  views     BlogPostView[]

  @@unique([baseLanguageCode, slug])
  @@map("blog_posts")
  @@index([status, publishedAt(sort: Desc)])
  @@index([baseLanguageCode, status])
}

// 博客文章编辑历史（每次保存草稿生成一条）
model BlogPostRevision {
  id               String   @id @default(uuid())
  postId           String
  revisionNo       Int
  title            String
  excerpt          String
  content          String
  coverImageUrl    String?
  tldr             String?
  seoTitle         String?
  seoDescription   String?
  tag              String
  readTime         String   @default("5 min read")
  baseLanguageCode String
  status           String
  editorId         String?
  createdAt        DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, revisionNo])
  @@map("blog_post_revisions")
  @@index([postId, revisionNo(sort: Desc)])
}

// 博客阅读量统计（用户访问 /blog/:slug 时记一条）
model BlogPostView {
  id        BigInt   @id @default(autoincrement())
  postId    String
  userId    String?
  viewedAt  DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("blog_post_views")
  @@index([postId])
  @@index([viewedAt(sort: Desc)])
}

// ============================================================
// P0: 用户学习进度核心表
// ============================================================

// 单词记忆状态（SM2 间隔重复）
model UserWordReview {
  id              String   @id @default(uuid())
  userId          String
  wordBankId      String
  easeFactor      Float    @default(2.5)
  interval        Int      @default(1)      // 天
  repetitions     Int      @default(0)
  nextReviewAt    DateTime @default(now())
  lastReviewAt    DateTime?
  lastRating      String?  // remembered | fuzzy | forgot
  totalReviews    Int      @default(0)
  correctReviews  Int      @default(0)
  isLearned       Boolean  @default(false)  // 首次记住后 true

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordBank WordBank @relation(fields: [wordBankId], references: [id], onDelete: Cascade)

  @@unique([userId, wordBankId])
  @@index([userId, nextReviewAt])
  @@map("user_word_reviews")
}

// 课程/课时进度
model UserCourseProgress {
  id               String    @id @default(uuid())
  userId           String
  courseId         String
  status           String    @default("not_started") // not_started | in_progress | completed
  currentLesson    Int       @default(0)
  completedLessons Json      @default("[]")           // [1, 2, 3] 已完成课时
  progressPercent  Int       @default(0)
  startedAt       DateTime?
  completedAt      DateTime?
  lastStudiedAt   DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId, lastStudiedAt])
  @@map("user_course_progress")
}

// ============================================================
// P0-1: 课时层级结构（Course → Unit → Lesson → Exercise）
// ============================================================

// 课程单元（一个 Course 下多个 Unit，按 unitOrder 排序）
model Unit {
  id          String   @id @default(uuid())
  courseId    String
  title       String                          // "Unit 1: Greetings"
  description String?
  unitOrder   Int      @default(0)
  skillFocus  String?                         // "vocabulary" | "grammar" | "listening" | "mixed"
  createdAt   DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, unitOrder])
  @@map("units")
}

// 单个课时（一个 Unit 下多个 Lesson，按 lessonOrder 排序）
model Lesson {
  id              String   @id @default(uuid())
  unitId          String
  title           String                          // "Lesson 1: Hello & Goodbye"
  lessonOrder     Int      @default(0)
  skillType       String                          // "vocab" | "grammar" | "listening" | "speaking" | "mixed"
  exerciseIds     Json                            // string[]，指向 WordBank/Quiz/Listening/Speaking 的 id
  durationMin     Int      @default(5)            // 预计耗时（分钟）
  isCheckpoint    Boolean  @default(false)        // 是否单元通关测验
  requiresLessonId String?                        // 前置课时（解锁条件）
  createdAt       DateTime @default(now())

  unit          Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  userProgress  UserLessonProgress[]

  @@unique([unitId, lessonOrder])
  @@map("lessons")
}

// 用户课时进度（解锁 + 完成）
model UserLessonProgress {
  id            String    @id @default(uuid())
  userId        String
  lessonId      String
  status        String    @default("locked")   // locked | unlocked | in_progress | completed
  startedAt     DateTime?
  completedAt   DateTime?
  bestScore     Int?                            // 通关测验得分
  attemptCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, status])
  @@map("user_lesson_progress")
}

// 测验作答记录（SM2 + 错题本）
model UserQuizReview {
  id              String    @id @default(uuid())
  userId          String
  quizId          String
  easeFactor      Float     @default(2.5)
  interval        Int       @default(1)
  repetitions     Int      @default(0)
  nextReviewAt    DateTime  @default(now())
  lastReviewAt    DateTime?
  wrongCount      Int      @default(0)
  lastWrongAt     DateTime?
  isMastered      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId, nextReviewAt])
  @@index([userId, isMastered])
  @@map("user_quiz_reviews")
}

// ============================================================
// P1: 用户练习记录
// ============================================================

// 听力练习进度
model UserListeningProgress {
  id              String    @id @default(uuid())
  userId          String
  listeningId     String
  status          String    @default("not_started") // not_started | in_progress | completed
  blankResults    Json      @default("[]")           // [{ index, correct, userAnswer }]
  correctCount    Int       @default(0)
  totalBlanks     Int       @default(0)
  attempts        Int       @default(0)
  bestAccuracy    Int       @default(0)              // 最佳正确率 %
  completedAt     DateTime?
  lastPracticedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listening Listening @relation(fields: [listeningId], references: [id], onDelete: Cascade)

  @@unique([userId, listeningId])
  @@index([userId, lastPracticedAt])
  @@map("user_listening_progress")
}

// 口语跟读记录
model UserSpeakingProgress {
  id              String    @id @default(uuid())
  userId          String
  speakingId      String
  attempts        Int       @default(0)
  scoreHistory    Json      @default("[]")           // [{ score, timestamp, audioUrl? }]
  bestScore       Int       @default(0)              // 0-100
  lastScore       Int       @default(0)
  isCompleted     Boolean   @default(false)           // 达到 60 分视为完成
  lastPracticedAt DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  speaking Speaking @relation(fields: [speakingId], references: [id], onDelete: Cascade)

  @@unique([userId, speakingId])
  @@index([userId, lastPracticedAt])
  @@map("user_speaking_progress")
}

// 成就解锁记录
model UserAchievement {
  id          String   @id @default(uuid())
  userId      String
  badgeKey    String                                  // 对应 badges.ts 里的 key
  unlockedAt  DateTime @default(now())
  isRead      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId, isRead])
  @@map("user_achievements")
}

// ============================================================
// P0-3: 分级测试结果（Placement Test）
// ============================================================

// 每个用户每个 (userId, language) 仅保留最近一次结果（upsert 覆盖）
model PlacementResult {
  id                  String   @id @default(uuid())
  userId              String
  language            String                                // "en" / "ja" / "ko" ...
  recommendedLevel    String                                // "A1" / "TOPIK3" / "N4" ...
  recommendedCourseId String?                               // 推荐起点的 course.id（可能为空）
  totalQuestions      Int                                   // 总题数
  correctCount        Int                                   // 答对数
  finalCefrRank       Int                                   // 1-6 (A1-C2)，用于跨语言比较
  answers             Json      @default("[]")              // [{level, itemId, correct}] 答题明细
  takenAt             DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, language])
  @@index([userId, takenAt])
  @@map("placement_results")
}

// ============================================================
// P1-2: 阅读模块（Reading Module）
//
// 与 Listening/Speaking/Quiz 平级，提供分级阅读理解材料。
// 设计要点：
//   * body 存纯文本正文（前端按段落渲染）；词汇注释 + 理解题
//     放 JSONB 字段（glossary / questions），避免 join 爆炸
//   * ReadingTranslation 仅翻译标题与摘要，题目本身在 questions
//     JSON 内自带 translation 字段（与 QuizTranslation 模式不同但更简单）
//   * UserReadingProgress 记录用户最佳作答，可重做
// ============================================================

model ReadingPassage {
  id           String   @id @default(uuid())
  languageCode String
  level        String                                  // CEFR / JLPT / HSK / TOPIK level
  title        String
  body         String                                  // 正文（纯文本，按 \n\n 分段）
  glossary     Json      @default("[]")                 // [{ term, reading?, definition, translation }]
  questions    Json      @default("[]")                 // [{ id, question, options[], answer, explain?, translations? }]
  wordCount    Int      @default(0)
  estMinutes   Int      @default(3)                     // 预计阅读时长（分钟）
  source       String?                                  // 来源署名（版权合规）
  readOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  language     Language              @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  translations ReadingTranslation[]
  userProgress UserReadingProgress[]

  @@map("reading_passages")
  @@index([languageCode, level])
}

model ReadingTranslation {
  id               String @id @default(uuid())
  readingId        String
  baseLanguageCode String
  title            String
  summary          String  @default("")

  passage ReadingPassage @relation(fields: [readingId], references: [id], onDelete: Cascade)

  @@map("reading_translations")
  @@unique([readingId, baseLanguageCode])
  @@index([baseLanguageCode])
}

model UserReadingProgress {
  id                   String    @id @default(uuid())
  userId               String
  readingId            String
  status               String    @default("not_started") // not_started | in_progress | completed
  comprehensionResults Json      @default("[]")            // [{ questionId, selectedIndex, correct }]
  correctCount         Int       @default(0)
  totalQuestions       Int       @default(0)
  bestAccuracy         Int       @default(0)               // 最佳正确率 %
  attemptCount         Int       @default(0)
  completedAt          DateTime?
  lastPracticedAt      DateTime?

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  passage ReadingPassage @relation(fields: [readingId], references: [id], onDelete: Cascade)

  @@unique([userId, readingId])
  @@index([userId, lastPracticedAt])
  @@map("user_reading_progress")
}

// ============================================================
// P1-3: SM-2 复习队列（听力 / 口语）
//
// 与 UserWordReview / UserQuizReview 同构：每条记录持有一个
// Listening / Speaking 项的 SM-2 状态，按 nextReviewAt 调度。
//
// 与 UserListeningProgress 的区别：
//   * UserListeningProgress 记录"用户做过这个练习"（每次重做覆盖最佳）
//   * UserListeningReview 记录"这条进入了 SM-2 复习队列"（按 SM-2 推进）
// 用户答错 / 评分低 → 主动加入复习队列；答对 → 调度下次复习时间。
// ============================================================

model UserListeningReview {
  id            String    @id @default(uuid())
  userId        String
  listeningId   String
  easeFactor    Float     @default(2.5)
  interval      Int       @default(1)
  repetitions   Int       @default(0)
  nextReviewAt  DateTime  @default(now())
  lastReviewAt  DateTime?
  lastRating    String?                       // again | hard | good | easy
  lastAccuracy  Int       @default(0)
  totalReviews  Int       @default(0)
  goodReviews   Int       @default(0)
  isMastered    Boolean   @default(false)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listening Listening @relation(fields: [listeningId], references: [id], onDelete: Cascade)

  @@unique([userId, listeningId])
  @@index([userId, nextReviewAt])
  @@index([userId, isMastered])
  @@map("user_listening_reviews")
}

model UserSpeakingReview {
  id            String    @id @default(uuid())
  userId        String
  speakingId    String
  easeFactor    Float     @default(2.5)
  interval      Int       @default(1)
  repetitions   Int       @default(0)
  nextReviewAt  DateTime  @default(now())
  lastReviewAt  DateTime?
  lastRating    String?
  lastScore     Int       @default(0)           // 0-100
  totalReviews  Int       @default(0)
  goodReviews   Int       @default(0)
  isMastered    Boolean   @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  speaking Speaking @relation(fields: [speakingId], references: [id], onDelete: Cascade)

  @@unique([userId, speakingId])
  @@index([userId, nextReviewAt])
  @@index([userId, isMastered])
  @@map("user_speaking_reviews")
}

// ============================================================
// P2-1: League 排行榜
//
// 设计：
//   * LeagueSeason：按周生成一个全局 season（seasonKey 形如 "2026-W29"）
//     isActive 通过 partial unique index 保证全局仅一条 active
//   * LeagueStanding：每用户每 season 一条；startingExp 记录入 season
//     时的用户总 XP，weekExp = currentExp - startingExp 用于排名
//   * Division 划分：bronze/silver/gold/platinum/diamond/master
//   * 排名（rankInDivision）由后端查询时即时计算，不物化
// ============================================================

model LeagueSeason {
  id          String   @id @default(uuid())
  seasonKey   String                                 // "2026-W29"
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  standings   LeagueStanding[]

  @@unique([seasonKey])
  @@map("league_seasons")
}

model LeagueStanding {
  id              String    @id @default(uuid())
  userId          String
  seasonId        String
  division        String    @default("bronze")       // bronze | silver | gold | platinum | diamond | master
  startingExp     Int       @default(0)
  currentExp      Int       @default(0)
  weekExp         Int       @default(0)               // currentExp - startingExp
  bestDivision    String?
  promotedAt      DateTime?
  demotedAt       DateTime?
  updatedAt       DateTime  @default(now()) @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  season LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, division, weekExp])
  @@index([userId])
  @@map("league_standings")
}

// ============================================================
// P2-2: CEFR 自评（Cefr Self-Assessment）
//
// 设计：
//   * 每用户每语言一条自评记录（upsert）
//   * cefrLevel (A1-C2) + cefrRank (1-6) 双字段，前者用于展示，后者用于排序
//   * canDoKeys 存用户勾选的 can-do 条目 key（项目原创描述，避免版权问题）
//   * 与 PlacementResult 分离：自评是主观，分级测试是客观
// ============================================================

model CefrSelfAssessment {
  id          String   @id @default(uuid())
  userId      String
  language    String                                 // "en" / "ja" / "ko" ...
  cefrLevel   String                                 // "A1" / "A2" / "B1" / "B2" / "C1" / "C2"
  cefrRank    Int                                    // 1-6 (A1=1 ... C2=6)
  canDoKeys   Json      @default("[]")               // string[]，用户勾选的 can-do 条目 key
  note        String?
  assessedAt  DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, language])
  @@index([userId])
  @@index([language, cefrRank])
  @@map("cefr_self_assessments")
}

// ============================================================
// P2-3: 写作模块（Writing Module）
//
// 设计要点：
//   * WritingPrompt：分级写作题目 + 提示词 + 范文 + 期望关键词
//   * WritingTranslation：题目/范文的本地化翻译（与 ReadingTranslation 同构）
//   * UserWritingSubmission：每次提交一条独立记录（保留全部历史，便于"作品集"展示）
//     与 UserReadingProgress 不同：reading 用 upsert-by-best，writing 累加历史
//
// 评分策略：
//   * 后端实现简单评分算法（字数 / 句子多样性 / 词汇多样性 / 关键词命中）
//   * score = lengthScore * 0.3 + varietyScore * 0.3 + keywordScore * 0.4
//   * 真正的 LLM 评分作为后续可插拔扩展（feedback 字段保留 rawFeedback 供回溯）
// ============================================================

model WritingPrompt {
  id           String   @id @default(uuid())
  languageCode String
  level        String                                // CEFR / JLPT / HSK / TOPIK level
  type         String   @default("essay")            // essay | email | summary | story | dialogue
  title        String
  prompt       String                                // 题目正文
  tips         Json      @default("[]")              // string[]
  minWords     Int      @default(50)
  maxWords     Int      @default(200)
  estMinutes   Int      @default(15)
  sampleAnswer String?
  keywords     Json      @default("[]")              // string[]，期望出现的关键词
  writeOrder   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  language     Language              @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  translations WritingTranslation[]
  submissions  UserWritingSubmission[]

  @@map("writing_prompts")
  @@index([languageCode, level])
  @@index([type])
}

model WritingTranslation {
  id               String  @id @default(uuid())
  writingId        String
  baseLanguageCode String
  title            String
  prompt           String
  tips             Json    @default("[]")           // string[]
  sampleAnswer     String?

  prompt_ref WritingPrompt @relation(fields: [writingId], references: [id], onDelete: Cascade)

  @@map("writing_translations")
  @@unique([writingId, baseLanguageCode])
  @@index([baseLanguageCode])
}

model UserWritingSubmission {
  id            String    @id @default(uuid())
  userId        String
  writingId     String
  content       String                              // 用户提交的写作文本
  wordCount     Int       @default(0)
  score         Int       @default(0)                // 0-100 综合评分
  lengthScore   Int       @default(0)                // 字数得分 0-100
  varietyScore  Int       @default(0)                // 词汇多样性 0-100
  keywordScore  Int       @default(0)                // 关键词命中 0-100
  feedback      Json      @default("{}")             // 结构化反馈
  status        String    @default("submitted")      // submitted | reviewed | flagged
  submittedAt   DateTime  @default(now())
  reviewedAt    DateTime?

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt WritingPrompt   @relation(fields: [writingId], references: [id], onDelete: Cascade)

  @@map("user_writing_submissions")
  @@index([userId, writingId])
  @@index([userId, submittedAt])
  @@index([writingId])
}
