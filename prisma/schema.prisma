// Prisma schema for the online learning platform
generator client {
  provider = "prisma-client-js"
  output   = "../server/lib/prisma-generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Language {
  code    String   @id
  name    String
  native  String
  flag    String
  tagline String
  levels  Json
  status  String   @default("active") // 'active' | 'coming_soon'

  courses   Course[]
  wordBank  WordBank[]
  quizzes   Quiz[]
  listening Listening[]
  speaking  Speaking[]
  users     User[]

  @@map("languages")
}

model Course {
  id           String   @id @default(uuid())
  languageCode String
  title        String
  level        String
  levelGroup   String   // beginner | intermediate | advanced
  description  String
  lessons      Int
  minutes      Int
  cover        String
  tags         Json
  vipOnly      Boolean  @default(false)
  courseOrder  Int      @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  userProgress UserCourseProgress[]

  @@map("courses")
}

model WordBank {
  id              String                  @id @default(uuid())
  languageCode    String
  level           String
  word            String
  phonetic        String?
  exampleSentence String
  vocabOrder      Int                     @default(0)

  language      Language                @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  translations  WordBankTranslation[]
  userReviews   UserWordReview[]

  @@map("word_bank")
  @@index([languageCode, level])
}

model WordBankTranslation {
  id                 String   @id @default(uuid())
  wordBankId         String
  baseLanguageCode   String   // 用户母语/释义语言，如 en/zh/ja/ko/es/fr/de
  translation        String
  exampleTranslation String?

  wordBank WordBank @relation(fields: [wordBankId], references: [id], onDelete: Cascade)

  @@map("word_bank_translations")
  @@unique([wordBankId, baseLanguageCode])
  @@index([baseLanguageCode])
  @@index([baseLanguageCode, wordBankId])
}

model Quiz {
  id           String             @id @default(uuid())
  languageCode String
  level        String
  options      Json               // string[]
  answer       Int                // index of correct option
  quizOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  language      Language           @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  translations  QuizTranslation[]
  userReviews   UserQuizReview[]

  @@map("quizzes")
  @@index([languageCode, level])
}

model QuizTranslation {
  id               String @id @default(uuid())
  quizId           String
  baseLanguageCode String
  question         String
  explain          String

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_translations")
  @@unique([quizId, baseLanguageCode])
  @@index([baseLanguageCode])
}

model Listening {
  id           String @id @default(uuid())
  languageCode String
  level        String
  title        String
  script       String
  blanks       Json   // { index: number; answer: string }[]
  listenOrder  Int    @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  userProgress UserListeningProgress[]

  @@map("listening")
  @@index([languageCode, level])
}

model Speaking {
  id           String  @id @default(uuid())
  languageCode String
  level        String
  phrase       String
  translation  String
  phonetic     String?
  speakOrder   Int     @default(0)

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)
  userProgress UserSpeakingProgress[]

  @@map("speaking")
  @@index([languageCode, level])
}

model User {
  id               String              @id @default(uuid())
  email            String              @unique
  username         String
  passwordHash     String?
  avatar           String?
  level            Int                 @default(1)
  exp              Int                 @default(0)
  streak           Int                 @default(0)
  lastActive       DateTime            @default(now())
  uiLanguage       String              @default("en") // 界面语言：en/zh/ja/ko/...
  nativeLanguage   String              @default("en") // 学习释义语言：en/zh/ja/ko/...
  targetLanguage   String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  role             String              @default("user") // user | vip | admin
  goalMinutesPerDay Int                @default(30)
  jwtVersion       Int                 @default(0)
  // OAuth 绑定信息：同一邮箱可关联多个 provider，null 表示该账号由密码注册
  oauthProvider    String?
  oauthId          String?
  // 邮箱验证：OAuth 用户默认视为已验证；密码注册用户默认 false
  emailVerified    Boolean             @default(false)

  language        Language             @relation(fields: [targetLanguage], references: [code], onDelete: Restrict)
  progressDays    UserProgressDay[]
  posts           Post[]
  likedPosts      LikePost[]
  comments        Comment[]
  subscription    Subscription?
  // P0: 学习进度
  wordReviews     UserWordReview[]
  courseProgress  UserCourseProgress[]
  quizReviews     UserQuizReview[]
  // P1: 练习记录
  listeningProgress UserListeningProgress[]
  speakingProgress  UserSpeakingProgress[]
  achievements      UserAchievement[]

  @@unique([oauthProvider, oauthId])
  @@map("users")
}

model UserProgressDay {
  id              String   @id @default(uuid())
  userId          String
  studyDate       DateTime
  minutes         Int      @default(0)
  wordsLearned    Int      @default(0)
  wordCorrect     Int      @default(0)
  wordTotal       Int      @default(0)
  quizzesDone     Int      @default(0)
  quizCorrect     Int      @default(0)
  quizTotal       Int      @default(0)
  speakingMinutes Int      @default(0)
  listeningMinutes Int     @default(0)
  moduleScores    Json     @default("{\"words\":0,\"grammar\":0,\"listening\":0,\"speaking\":0}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, studyDate])
  @@map("user_progress_days")
}

model Post {
  id        String   @id @default(uuid())
  authorId  String
  topic     String
  content   String
  createdAt DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    LikePost[]
  comments Comment[]

  @@map("posts")
}

model LikePost {
  id     String @id @default(uuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("like_posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Subscription {
  id                  String   @id @default(uuid())
  userId              String   @unique
  stripeCustomerId    String?
  stripeSubscriptionId String?
  stripePriceId       String?
  status              String   @default("inactive")
  tier                String   @default("free") // free | basic | vip
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean  @default(false)
  amountTotal         Int      @default(0)
  currency            String   @default("usd")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// Stripe webhook 事件记录（幂等性保证）
model StripeEvent {
  id            String   @id // Stripe event ID (evt_xxx)
  type          String   // event type: checkout.session.completed, etc.
  processedAt   DateTime @default(now())
  payload       Json     // 原始 event payload（用于审计）
  userId        String?  // 关联用户（可选，从 metadata 提取）

  @@map("stripe_events")
}

// Blog posts (CMS) —— Markdown 内容，多语言由 baseLanguageCode 区分
model BlogPost {
  id               String   @id @default(uuid())
  slug             String
  title            String
  excerpt          String
  content          String   // 整篇 markdown 文本（不再用 JSON 数组）
  tag              String
  readTime         String   @default("5 min read")
  coverEmoji       String?  // 文章封面 emoji，备用
  coverImageUrl    String?  // OG 图/封面图 URL（可选）
  tldr             String?  // 1-2 句简短引子
  seoTitle         String?  // SEO 独立标题
  seoDescription   String?  // SEO 独立描述
  baseLanguageCode String   @default("en") // en/zh/ja/ko/es/fr/de
  status           String   @default("draft") // draft | published
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  revisions BlogPostRevision[]
  views     BlogPostView[]

  @@unique([baseLanguageCode, slug])
  @@map("blog_posts")
  @@index([status, publishedAt(sort: Desc)])
  @@index([baseLanguageCode, status])
}

// 博客文章编辑历史（每次保存草稿生成一条）
model BlogPostRevision {
  id               String   @id @default(uuid())
  postId           String
  revisionNo       Int
  title            String
  excerpt          String
  content          String
  coverImageUrl    String?
  tldr             String?
  seoTitle         String?
  seoDescription   String?
  tag              String
  readTime         String   @default("5 min read")
  baseLanguageCode String
  status           String
  editorId         String?
  createdAt        DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, revisionNo])
  @@map("blog_post_revisions")
  @@index([postId, revisionNo(sort: Desc)])
}

// 博客阅读量统计（用户访问 /blog/:slug 时记一条）
model BlogPostView {
  id        BigInt   @id @default(autoincrement())
  postId    String
  userId    String?
  viewedAt  DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("blog_post_views")
  @@index([postId])
  @@index([viewedAt(sort: Desc)])
}

// ============================================================
// P0: 用户学习进度核心表
// ============================================================

// 单词记忆状态（SM2 间隔重复）
model UserWordReview {
  id              String   @id @default(uuid())
  userId          String
  wordBankId      String
  easeFactor      Float    @default(2.5)
  interval        Int      @default(1)      // 天
  repetitions     Int      @default(0)
  nextReviewAt    DateTime @default(now())
  lastReviewAt    DateTime?
  lastRating      String?  // remembered | fuzzy | forgot
  totalReviews    Int      @default(0)
  correctReviews  Int      @default(0)
  isLearned       Boolean  @default(false)  // 首次记住后 true

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordBank WordBank @relation(fields: [wordBankId], references: [id], onDelete: Cascade)

  @@unique([userId, wordBankId])
  @@index([userId, nextReviewAt])
  @@map("user_word_reviews")
}

// 课程/课时进度
model UserCourseProgress {
  id               String    @id @default(uuid())
  userId           String
  courseId         String
  status           String    @default("not_started") // not_started | in_progress | completed
  currentLesson    Int       @default(0)
  completedLessons Json      @default("[]")           // [1, 2, 3] 已完成课时
  progressPercent  Int       @default(0)
  startedAt       DateTime?
  completedAt      DateTime?
  lastStudiedAt   DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId, lastStudiedAt])
  @@map("user_course_progress")
}

// 测验作答记录（SM2 + 错题本）
model UserQuizReview {
  id              String    @id @default(uuid())
  userId          String
  quizId          String
  easeFactor      Float     @default(2.5)
  interval        Int       @default(1)
  repetitions     Int      @default(0)
  nextReviewAt    DateTime  @default(now())
  lastReviewAt    DateTime?
  wrongCount      Int      @default(0)
  lastWrongAt     DateTime?
  isMastered      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId, nextReviewAt])
  @@index([userId, isMastered])
  @@map("user_quiz_reviews")
}

// ============================================================
// P1: 用户练习记录
// ============================================================

// 听力练习进度
model UserListeningProgress {
  id              String    @id @default(uuid())
  userId          String
  listeningId     String
  status          String    @default("not_started") // not_started | in_progress | completed
  blankResults    Json      @default("[]")           // [{ index, correct, userAnswer }]
  correctCount    Int       @default(0)
  totalBlanks     Int       @default(0)
  attempts        Int       @default(0)
  bestAccuracy    Int       @default(0)              // 最佳正确率 %
  completedAt     DateTime?
  lastPracticedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listening Listening @relation(fields: [listeningId], references: [id], onDelete: Cascade)

  @@unique([userId, listeningId])
  @@index([userId, lastPracticedAt])
  @@map("user_listening_progress")
}

// 口语跟读记录
model UserSpeakingProgress {
  id              String    @id @default(uuid())
  userId          String
  speakingId      String
  attempts        Int       @default(0)
  scoreHistory    Json      @default("[]")           // [{ score, timestamp, audioUrl? }]
  bestScore       Int       @default(0)              // 0-100
  lastScore       Int       @default(0)
  isCompleted     Boolean   @default(false)           // 达到 60 分视为完成
  lastPracticedAt DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  speaking Speaking @relation(fields: [speakingId], references: [id], onDelete: Cascade)

  @@unique([userId, speakingId])
  @@index([userId, lastPracticedAt])
  @@map("user_speaking_progress")
}

// 成就解锁记录
model UserAchievement {
  id          String   @id @default(uuid())
  userId      String
  badgeKey    String                                  // 对应 badges.ts 里的 key
  unlockedAt  DateTime @default(now())
  isRead      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId, isRead])
  @@map("user_achievements")
}
